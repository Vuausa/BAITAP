@model IEnumerable<WebApp.Models.Book>
@{
    ViewData["Title"] = "Danh sách sách";
}

<h2>Book Management</h2>
<p>Danh sách sách</p>

<a asp-action="Create" class="btn btn-success mb-3">Thêm sách</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Id</td>
                <td>@book.Name</td>
                <td>@book.Price</td>
                <td>
                    <a asp-action="Detail" asp-route-id="@book.Id" class="btn btn-sm btn-info">Chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>
