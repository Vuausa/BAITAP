@model List<Book>

@{
    ViewData["Title"] = "Danh sach sach";
}

<h2 class="mb-4">Danh sach sach</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Them sach moi</a>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Ten sach</th>
            <th>Gia</th>
            <th>Hanh dong</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Id</td>
                <td>@book.Title</td>
                <td>@book.Price.ToString("N0") VND</td>
                <td>
                    <a asp-action="Detail" asp-route-id="@book.Id" class="btn btn-info btn-sm">Chi tiet</a>
                </td>
            </tr>
        }
    </tbody>
</table>
