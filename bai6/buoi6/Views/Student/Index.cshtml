@model List<buoi6.Models.Student>
@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách sinh viên</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Thêm mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-8">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control"
                       placeholder="Tìm kiếm theo tên, email, số điện thoại, ngành học..." />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-outline-primary me-2">Tìm kiếm</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Xóa bộ lọc</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        <p class="mb-0">Chưa có dữ liệu sinh viên nào.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a asp-action="Index" asp-route-search="@ViewBag.Search"
                           asp-route-sortBy="Id" asp-route-sortOrder="@(ViewBag.SortBy == "Id" && ViewBag.SortOrder == "asc" ? "desc" : "asc")"
                           class="text-white text-decoration-none">
                            Id @(ViewBag.SortBy == "Id" ? (ViewBag.SortOrder == "asc" ? "▲" : "▼") : "")
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-search="@ViewBag.Search"
                           asp-route-sortBy="Name" asp-route-sortOrder="@(ViewBag.SortBy == "Name" && ViewBag.SortOrder == "asc" ? "desc" : "asc")"
                           class="text-white text-decoration-none">
                            Họ và tên @(ViewBag.SortBy == "Name" ? (ViewBag.SortOrder == "asc" ? "▲" : "▼") : "")
                        </a>
                    </th>
                    <th>
                        <a asp-action="Index" asp-route-search="@ViewBag.Search"
                           asp-route-sortBy="Email" asp-route-sortOrder="@(ViewBag.SortBy == "Email" && ViewBag.SortOrder == "asc" ? "desc" : "asc")"
                           class="text-white text-decoration-none">
                            Email @(ViewBag.SortBy == "Email" ? (ViewBag.SortOrder == "asc" ? "▲" : "▼") : "")
                        </a>
                    </th>
                    <th>Số điện thoại</th>
                    <th>Ngành học</th>
                    <th>
                        <a asp-action="Index" asp-route-search="@ViewBag.Search"
                           asp-route-sortBy="Age" asp-route-sortOrder="@(ViewBag.SortBy == "Age" && ViewBag.SortOrder == "asc" ? "desc" : "asc")"
                           class="text-white text-decoration-none">
                            Tuổi @(ViewBag.SortBy == "Age" ? (ViewBag.SortOrder == "asc" ? "▲" : "▼") : "")
                        </a>
                    </th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.Major</td>
                        <td>@item.Age</td>
                        <td class="text-center">
                            <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted">Tổng cộng: <strong>@Model.Count</strong> sinh viên</p>
}

@section Scripts {
    <script>
        console.log("Trang danh sách sinh viên đã được tải");
    </script>
}
