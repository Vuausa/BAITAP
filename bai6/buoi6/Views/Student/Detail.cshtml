@model buoi6.Models.Student
@{
    ViewData["Title"] = "Chi tiết sinh viên";
}

<h2>Chi tiết sinh viên</h2>

<div class="card mt-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Id</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Họ và tên</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Số điện thoại</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Ngành học</dt>
            <dd class="col-sm-9">@Model.Major</dd>

            <dt class="col-sm-3">Tuổi</dt>
            <dd class="col-sm-9">@Model.Age</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Xóa</a>
</div>

@section Scripts {
    <script>
        console.log("Trang chi tiết sinh viên đã được tải");
    </script>
}
